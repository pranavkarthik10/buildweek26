RENDER_WORKER_CONCURRENCY="1"

# Optional Cloudflare R2 artifact publishing.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""
