generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id // Application user id
  email         String    @unique
  name          String?
  image         String?
  decks         Deck[]
  studySessions StudySession[]
  conceptStates ConceptState[]
  reviewItems   ReviewItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Deck {
  id            String   @id @default(cuid())
  userId        String
  title         String
  courseName    String?
  summary       String?
  studyStrategy String?
  pdfUrl        String
  totalSlides   Int
  slides        String    // JSON stringified LectureSlide[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studySessions StudySession[]
}

model StudySession {
  id              String          @id @default(cuid())
  userId          String
  deckId          String
  teachingFormat  TeachingFormat  @default(lecture)
  customInstructions String?
  currentSlide    Int             @default(0)
  currentCue      Int             @default(0)
  status          SessionStatus   @default(active)
  progressPercent Int             @default(0)
  boardSnapshot   String?
  boardVersion    Int             @default(0)
  lastEventSeq    Int             @default(0)
  lastProgressSeq Int             @default(0)
  slideProgress   SlideProgress[]
  artifacts       Artifact[]
  turns           SessionTurn[]
  events          SessionEvent[]
  boardDocument   BoardDocument?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  completedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

model SlideProgress {
  id           String   @id @default(cuid())
  sessionId    String
  slideIndex   Int
  completed    Boolean  @default(false)
  timeSpentSec Int      @default(0)
  updatedAt    DateTime @updatedAt

  session StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, slideIndex])
}

enum SessionStatus {
  active
  paused
  completed
}

enum TeachingFormat {
  lecture
  small_class
  tutoring
}

model Artifact {
  id          String          @id @default(cuid())
  sessionId   String?
  jobKey      String          @unique
  status      RenderJobStatus @default(preview)
  kind        VisualArtifactKind @default(interactive)
  engine      RenderEngine    @default(diagram)
  spec        String
  artifactUrl String?
  audioUrl    String?
  captions    String?
  specVersion Int             @default(2)
  error       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  session StudySession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SessionTurn {
  id                String       @id @default(cuid())
  sessionId         String
  role              String
  modality          String
  transcript        String?
  startedAtMs       Int?
  durationMs        Int?
  toolCallMetadata  String?
  signalKey         String?
  createdAt         DateTime     @default(now())

  session StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@unique([sessionId, signalKey])
}

model SessionEvent {
  id             String       @id @default(cuid())
  sessionId      String
  clientEventId  String?
  sequence       Int
  kind           String
  slideIndex     Int?
  relativeTimeMs Int?
  payload        String
  createdAt      DateTime     @default(now())

  session StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@unique([sessionId, clientEventId])
  @@index([sessionId, createdAt])
}

model BoardDocument {
  id              String      @id @default(cuid())
  sessionId       String      @unique
  version         Int         @default(0)
  snapshot        String
  semanticSummary String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  session StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ConceptState {
  id                       String   @id @default(cuid())
  userId                   String
  conceptKey               String
  masteryScore             Float    @default(0)
  misconceptionEvidence    String?
  preferredExplanationStyle String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptKey])
  @@index([userId, updatedAt])
}

model ReviewItem {
  id             String   @id @default(cuid())
  userId         String
  conceptKey     String
  prompt         String
  dueAt          DateTime
  intervalSec    Int      @default(86400)
  latestOutcome  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueAt])
}

enum RenderJobStatus {
  preview
  queued
  processing
  completed
  failed
}

enum RenderEngine {
  diagram
  jsxgraph
  plotly
  manim
}

enum VisualArtifactKind {
  interactive
  video
}
